{
  "seed": 7,
  "dataset": {
    "train_samples": 900,
    "test_samples": 300,
    "coordinate_min": -1.0,
    "coordinate_max": 1.0,
    "circle_radius": 0.78,
    "center_x": 0.2,
    "center_y": -0.1
  },
  "model": {
    "input_size": 2,
    "hidden_size": 10,
    "hidden_activation": "relu"
  },
  "training": {
    "epochs": 220,
    "learning_rate": 0.12,
    "batch_size": 24,
    "report_every": 20,
    "loss_function": "binary_cross_entropy",
    "optimization_method": "gradient_descent",
    "early_stopping_patience": 25,
    "early_stopping_min_delta": 0.0005,
    "l2_lambda": 0.0002,
    "gradient_clip_value": 2.5,
    "learning_rate_decay": 0.015,
    "momentum": 0.82,
    "mistake_focus_power": 1.15,
    "bias_learning_rate_multiplier": 1.1
  },
  "artifacts": {
    "model_path": "artifacts/model_params.json",
    "history_path": "artifacts/training_history.csv"
  }
}
